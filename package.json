{
    "author": "ICJR",
    "bin": {
        "esportsplus-tsc": "./bin/tsc",
        "esportsplus-tsc-alias": "./bin/tsc-alias",
        "tsc": "./bin/tsc",
        "tsc-alias": "./bin/tsc-alias"
    },
    "dependencies": {
        "@esportsplus/cli-passthrough": "^0.0.15",
        "@esportsplus/utilities": "^0.27.3",
        "@types/node": "^25.6.0",
        "tsc-alias": "^1.8.16",
        "typescript": "^6.0.2"
    },
    "devDependencies": {
        "vite": "^8.0.8",
        "vitest": "^4.1.4"
    },
    "exports": {
        "./package.json": "./package.json",
        "./tsconfig.browser.json": "./tsconfig.browser.json",
        "./tsconfig.node.json": "./tsconfig.node.json",
        "./tsconfig.package.json": "./tsconfig.package.json",
        "./compiler": {
            "types": "./build/compiler/index.d.ts",
            "default": "./build/compiler/index.js"
        },
        ".": {
            "types": "./build/index.d.ts",
            "default": "./build/index.js"
        }
    },
    "main": "build/index.js",
    "name": "@esportsplus/typescript",
    "private": false,
    "repository": {
        "type": "git",
        "url": "https://github.com/esportsplus/typescript"
    },
    "scripts": {
        "build": "tsc && tsc-alias",
        "-": "-",
        "prepare": "pnpm build",
        "prepublishOnly": "pnpm build",
        "test": "vitest run"
    },
    "type": "module",
    "types": "build/index.d.ts",
    "version": "0.29.0"
}
